# ============================================================
# PubMed-Research-Agent  Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Application ---
APP_NAME=PubMed-Research-Agent
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# --- FastAPI Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Streamlit Frontend ---
FRONTEND_PORT=8501
BACKEND_API_URL=http://localhost:8000/api/v1

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./database/pubmed_agent.db
# For PostgreSQL production:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/pubmed_agent

# --- PubMed ---
# Optional: NCBI API Key for higher rate limit (10 req/s vs 3 req/s)
# Register at: https://account.ncbi.nlm.nih.gov/settings/
PUBMED_API_KEY=
PUBMED_TOOL_NAME=PubMed-Research-Agent
PUBMED_EMAIL=your_email@example.com

# --- LLM (OpenAI Compatible Interface) ---
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Alternative: local vLLM / Ollama
# LLM_API_BASE=http://localhost:8000/v1
# LLM_API_KEY=not-needed
# LLM_MODEL=meta-llama/Meta-Llama-3-70B-Instruct

# --- Embedding Model (for RAG) ---
EMBEDDING_API_BASE=${LLM_API_BASE}
EMBEDDING_API_KEY=${LLM_API_KEY}
EMBEDDING_MODEL=text-embedding-3-small

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=pubmed_articles

# --- Rate Limiting ---
PUBMED_RATE_LIMIT=3
PUBMED_RATE_LIMIT_WITH_KEY=10
